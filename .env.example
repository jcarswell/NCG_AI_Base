# Example .env file for NCG
# Copy this to .env and fill in your credentials
# DO NOT commit actual credentials to repository!

# ServiceNow Configuration
SERVICENOW_URL=https://dev12345.service-now.com
SERVICENOW_USER=api_user
SERVICENOW_PASSWORD=your-password-here
SERVICENOW_TIMEOUT=30

# SecretServer Configuration
SECRETSERVER_URL=https://secretserver.example.com
SECRETSERVER_USER=api_user
SECRETSERVER_PASSWORD=your-password-here
SECRETSERVER_TIMEOUT=30

# Template Configuration
TEMPLATE_DIR=./templates
DEVICE_OVERRIDE_DIR=./overrides
OUTPUT_DIR=./output

# Application Configuration
LOG_LEVEL=INFO
DEBUG=false
